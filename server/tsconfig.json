{
  "compilerOptions": {
    "target": "ES2020",
    "module": "esnext",
    "moduleResolution": "bundler",

    "rootDir": ".",
    "outDir": "../dist/server",

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,

    "ignoreDeprecations": "6.0",
    "baseUrl": "..",
    "paths": {
      "@shared/*": ["shared/*"]
    }
  },
  "include": ["**/*.ts"],
  "exclude": [
    "../client",
    "../vite.config.ts",
    "../node_modules"
  ]
}